<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Services — Admin</title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="/css/admin.css">
</head>
<body class="admin-body">

<%- include('../partials/admin-nav', { navPages, unreadCount, pageName: 'services' }) %>

<main class="admin-main">
  <div class="content-card">
    <h2 style="margin-bottom:0.5rem;color:var(--blue);">My Services</h2>
    <p style="margin-bottom:1.5rem;color:#666;font-size:0.92rem;">Tap an icon to change it. Edit the title and description, then tap Save.</p>

    <div id="servicesList">
      <% services.forEach(s => { %>
        <div class="service-item" data-id="<%= s.id %>">
          <div class="svc-icon-wrap">
            <button type="button" class="icon-preview-btn" onclick="toggleIconPicker(this)" title="Tap to change icon">
              <i data-lucide="<%= s.icon %>"></i>
            </button>
            <input type="hidden" class="svc-icon" value="<%= s.icon %>">
            <div class="icon-picker-grid" hidden></div>
          </div>
          <div class="service-item-fields">
            <input type="text" class="svc-title" value="<%= s.title %>" placeholder="Service title" maxlength="200">
            <textarea class="svc-desc" rows="2" placeholder="Description" maxlength="1000"><%= s.description %></textarea>
          </div>
          <div class="service-item-actions">
            <button class="btn-sm btn-gold" onclick="saveService(<%= s.id %>, this)">Save</button>
            <button class="btn-sm btn-danger" onclick="deleteService(<%= s.id %>, this)">Delete</button>
          </div>
        </div>
      <% }) %>
    </div>

    <div class="add-item-form" style="margin-top:2rem;border-top:1px solid #eee;padding-top:1.5rem;">
      <h3 style="margin-bottom:1rem;font-size:1rem;color:var(--blue);">Add a New Service</h3>
      <div style="display:flex;align-items:flex-start;gap:0.75rem;flex-wrap:wrap;">
        <div class="svc-icon-wrap">
          <button type="button" class="icon-preview-btn" onclick="toggleIconPicker(this)" title="Tap to choose icon">
            <i data-lucide="pencil-line"></i>
          </button>
          <input type="hidden" id="newIcon" value="pencil-line">
          <div class="icon-picker-grid" hidden></div>
        </div>
        <input type="text" id="newTitle" placeholder="Service title" maxlength="200" style="flex:1;min-width:180px;">
      </div>
      <textarea id="newDesc" rows="2" placeholder="Brief description of this service..." maxlength="1000" style="width:100%;margin-top:0.75rem;"></textarea>
      <button class="btn btn-gold" style="margin-top:0.75rem;" onclick="addService()">+ Add Service</button>
      <p id="addMsg" style="margin-top:0.5rem;color:var(--green);display:none;">✓ Service added!</p>
    </div>
  </div>
</main>

<script>
const SERVICE_ICONS = [
  'book-open','pencil-line','graduation-cap','lightbulb','users','star','award',
  'target','clipboard-list','calendar','search','file-text','check-circle',
  'briefcase','brain','trophy','heart','compass','notebook','user-check',
  'map','bookmark','pen-tool','layers','school','route'
];

function buildPickerGrid(grid) {
  grid.innerHTML = SERVICE_ICONS.map(ico =>
    `<button type="button" class="icon-opt" data-icon="${ico}" onclick="selectIcon(this)" title="${ico}"><i data-lucide="${ico}"></i></button>`
  ).join('');
  lucide.createIcons({ el: grid });
}

function toggleIconPicker(btn) {
  const wrap = btn.closest('.svc-icon-wrap');
  const grid = wrap.querySelector('.icon-picker-grid');
  if (!grid.hidden) { grid.hidden = true; return; }
  if (!grid.children.length) buildPickerGrid(grid);
  document.querySelectorAll('.icon-picker-grid').forEach(g => { if (g !== grid) g.hidden = true; });
  grid.hidden = false;
}

function selectIcon(btn) {
  const ico = btn.dataset.icon;
  const wrap = btn.closest('.svc-icon-wrap');
  const input = wrap.querySelector('[type="hidden"]');
  const preview = wrap.querySelector('.icon-preview-btn');
  input.value = ico;
  preview.innerHTML = `<i data-lucide="${ico}"></i>`;
  lucide.createIcons({ el: preview });
  wrap.querySelector('.icon-picker-grid').hidden = true;
}

async function saveService(id, btn) {
  const row = btn.closest('.service-item');
  const title = row.querySelector('.svc-title').value;
  const description = row.querySelector('.svc-desc').value;
  const icon = row.querySelector('.svc-icon').value;
  const r = await fetch(`/admin/api/services/${id}`, { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify({title, description, icon}) });
  const d = await r.json();
  btn.textContent = d.ok ? '✓ Saved' : 'Error';
  setTimeout(() => btn.textContent = 'Save', 2000);
}

async function deleteService(id, btn) {
  if (!confirm('Delete this service? It will be removed from the website.')) return;
  const r = await fetch(`/admin/api/services/${id}/delete`, { method:'POST' });
  const d = await r.json();
  if (d.ok) btn.closest('.service-item').remove();
  else alert('Could not delete. Please try again.');
}

async function addService() {
  const icon = document.getElementById('newIcon').value || 'pencil-line';
  const title = document.getElementById('newTitle').value.trim();
  const description = document.getElementById('newDesc').value.trim();
  if (!title) { alert('Please enter a title for the service.'); return; }
  const r = await fetch('/admin/api/services', { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify({title, description, icon}) });
  const d = await r.json();
  if (d.ok) {
    document.getElementById('addMsg').style.display = 'block';
    setTimeout(() => location.reload(), 800);
  } else alert(d.error || 'Could not add service.');
}

document.addEventListener('click', e => {
  if (!e.target.closest('.svc-icon-wrap')) {
    document.querySelectorAll('.icon-picker-grid').forEach(g => g.hidden = true);
  }
});
</script>
</body>
</html>
