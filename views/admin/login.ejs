<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Login — SRK Consulting</title>
  <link rel="icon" href="/images/butterfly.png" type="image/png">
  <link rel="stylesheet" href="/css/admin.css">
</head>
<body>

<div class="login-page">
  <div class="login-card">
    <div class="login-logo">
      <%- include('../partials/butterfly', { bfClass: 'login-butterfly' }) %>
      <h2>SRK Consulting</h2>
      <p>Website Admin</p>
    </div>

    <% if (error) { %>
      <div class="login-error"><%= error %></div>
    <% } %>

    <form method="POST" action="/admin/login" class="login-form">
      <div class="form-group">
        <label for="username">Username</label>
        <input type="text" id="username" name="username" autocomplete="username" autocapitalize="none" required>
      </div>
      <div class="form-group">
        <label for="password">Password</label>
        <input type="password" id="password" name="password" autocomplete="current-password" required>
      </div>
      <button type="submit" class="login-btn">Log In</button>
    </form>
  </div>
</div>

</body>
</html>
