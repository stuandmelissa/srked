<%- include('partials/header', { title, page, navPages, socialLinks }) %>

<div class="page-banner">
  <div class="container">
    <h1><%= content.page_title %></h1>
    <% if (content.intro_text) { %><p><%= content.intro_text %></p><% } %>
  </div>
</div>

<section class="section">
  <div class="container">
    <% if (items.length === 0) { %>
      <p style="text-align:center;color:#888;">Resources coming soon!</p>
    <% } else { %>
      <div class="resources-list">
        <% items.forEach(r => { %>
          <div class="resource-card">
            <div class="resource-info">
              <h3><%= r.title %></h3>
              <% if (r.description) { %><p><%= r.description %></p><% } %>
            </div>
            <% if (r.url) { %>
              <a href="<%= r.url %>" target="_blank" rel="noopener noreferrer" class="btn btn-gold btn-sm">Visit ↗</a>
            <% } %>
          </div>
        <% }) %>
      </div>
    <% } %>
  </div>
</section>

<%- include('partials/footer') %>
