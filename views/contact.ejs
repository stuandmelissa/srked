<%- include('partials/header', { title, page }) %>

<div class="page-banner">
  <div class="container">
    <h1><%= content.page_title %></h1>
    <% if (content.intro_text) { %><p><%= content.intro_text %></p><% } %>
  </div>
</div>

<section class="section">
  <div class="container">
    <div class="contact-grid">

      <div>
        <% if (error) { %>
          <div class="alert alert-error"><%= error %></div>
        <% } %>
        <div class="contact-form">
          <h2 style="font-size:1.4rem;margin-bottom:1.5rem;color:var(--blue);">Send a Message</h2>
          <form method="POST" action="/contact" novalidate>
            <div class="form-group">
              <label for="name">Your Name <span style="color:#c0392b;">*</span></label>
              <input type="text" id="name" name="name" placeholder="Jane Smith" required autocomplete="name">
            </div>
            <div class="form-group">
              <label for="email">Email Address <span style="color:#c0392b;">*</span></label>
              <input type="email" id="email" name="email" placeholder="jane@example.com" required autocomplete="email">
            </div>
            <div class="form-group">
              <label for="phone">Phone Number <span style="color:#999;font-weight:400;">(optional)</span></label>
              <input type="tel" id="phone" name="phone" placeholder="(555) 123-4567" autocomplete="tel">
            </div>
            <div class="form-group">
              <label for="message">Message <span style="color:#c0392b;">*</span></label>
              <textarea id="message" name="message" placeholder="Tell me about your student and how I can help..." required></textarea>
            </div>
            <button type="submit" class="btn-submit">Send Message</button>
          </form>
        </div>
      </div>

      <div>
        <div class="contact-info">
          <h3>Contact Info</h3>
          <div class="contact-info-item">
            <span class="icon"><i data-lucide="mail"></i></span>
            <p><a href="mailto:info@srked.com">info@srked.com</a></p>
          </div>
          <div class="contact-info-item">
            <span class="icon"><i data-lucide="clock"></i></span>
            <p>I typically respond within 24 hours.</p>
          </div>
          <div class="contact-info-item">
            <span class="icon"><%- include('partials/butterfly', { bfClass: 'contact-butterfly' }) %></span>
            <p>Every student deserves support. I'm here to help your family find the right path.</p>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

<%- include('partials/footer') %>
