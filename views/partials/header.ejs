<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <meta name="description" content="SRK Consulting — Educational Consulting & Tutoring. Helping students discover their potential.">
  <link rel="icon" href="/images/butterfly.png" type="image/png">
  <link rel="apple-touch-icon" href="/images/butterfly.png">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>

<nav class="nav" role="navigation" aria-label="Main navigation">
  <a href="/" class="nav-brand" aria-label="SRK Consulting Home">
    <%- include('butterfly', { bfClass: 'nav-butterfly' }) %>
    <span>SRK Consulting</span>
  </a>

  <ul class="nav-links" role="list">
    <% navPages.forEach(p => { %>
      <li><a href="<%= p.page_type === 'home' ? '/' : '/' + p.slug %>" class="<%= page === p.slug ? 'active' : '' %>"><%= p.nav_label %></a></li>
    <% }) %>
  </ul>

  <button class="nav-toggle" id="navToggle" aria-label="Toggle menu" aria-expanded="false">
    <span></span><span></span><span></span>
  </button>
</nav>

<div class="nav-mobile" id="navMobile" aria-hidden="true">
  <ul role="list">
    <% navPages.forEach(p => { %>
      <li><a href="<%= p.page_type === 'home' ? '/' : '/' + p.slug %>"><%= p.nav_label %></a></li>
    <% }) %>
  </ul>
</div>

<div class="page-content">
