<header class="admin-header">
  <button class="admin-menu-btn" onclick="toggleAdminNav(this)" aria-expanded="false" aria-controls="adminNavPanel">
    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
    <span class="hamburger-label">Menu</span>
  </button>
  <a href="/admin" class="admin-brand-center">
    <%- include('./butterfly', { bfClass: 'nav-butterfly' }) %>
    <span>SRK Admin</span>
  </a>
  <a href="/admin/logout" class="admin-logout">Log out</a>
</header>

<div id="adminNavOverlay" class="admin-nav-overlay" onclick="closeAdminNav()"></div>

<nav id="adminNavPanel" class="admin-nav-panel" aria-label="Admin navigation">
  <div class="admin-nav-section">
    <div class="admin-nav-section-label">Edit Content</div>
    <% navPages.forEach(p => { %>
      <a href="/admin/page/<%= p.slug %>"
         class="admin-nav-item <%= (typeof pageName !== 'undefined' && pageName === p.slug) ? 'active' : '' %>">
        <span class="nav-item-icon"><i data-lucide="file-text"></i></span>
        <%= p.nav_label %>
      </a>
    <% }) %>
  </div>
  <div class="admin-nav-divider"></div>
  <div class="admin-nav-section">
    <div class="admin-nav-section-label">Manage Site</div>
    <a href="/admin/services" class="admin-nav-item <%= (typeof pageName !== 'undefined' && pageName === 'services') ? 'active' : '' %>">
      <span class="nav-item-icon"><i data-lucide="settings-2"></i></span>
      Services
    </a>
    <a href="/admin/pages" class="admin-nav-item <%= (typeof pageName !== 'undefined' && pageName === 'pages') ? 'active' : '' %>">
      <span class="nav-item-icon"><i data-lucide="layout-grid"></i></span>
      Pages
    </a>
    <a href="/admin/messages" class="admin-nav-item <%= (typeof pageName !== 'undefined' && pageName === 'messages') ? 'active' : '' %>">
      <span class="nav-item-icon"><i data-lucide="mail"></i></span>
      Messages
      <% if (typeof unreadCount !== 'undefined' && unreadCount > 0) { %>
        <span class="badge"><%= unreadCount %></span>
      <% } %>
    </a>
    <a href="/admin/settings" class="admin-nav-item <%= (typeof pageName !== 'undefined' && pageName === 'settings') ? 'active' : '' %>">
      <span class="nav-item-icon"><i data-lucide="settings"></i></span>
      Settings
    </a>
  </div>
</nav>

<script src="https://unpkg.com/lucide@latest/dist/umd/lucide.min.js"></script>
<script>
(function() {
  if (!document.head.querySelector('link[rel="icon"]')) {
    const l = document.createElement('link');
    l.rel = 'icon'; l.href = '/images/butterfly.png'; l.type = 'image/png';
    document.head.appendChild(l);
  }
})();
document.addEventListener('DOMContentLoaded', () => lucide.createIcons());

function toggleAdminNav(btn) {
  const panel = document.getElementById('adminNavPanel');
  const overlay = document.getElementById('adminNavOverlay');
  if (panel.classList.contains('open')) { closeAdminNav(); return; }
  panel.classList.add('open');
  overlay.classList.add('open');
  btn.setAttribute('aria-expanded', 'true');
  document.body.style.overflow = 'hidden';
}
function closeAdminNav() {
  document.getElementById('adminNavPanel').classList.remove('open');
  document.getElementById('adminNavOverlay').classList.remove('open');
  const btn = document.querySelector('.admin-menu-btn');
  if (btn) btn.setAttribute('aria-expanded', 'false');
  document.body.style.overflow = '';
}
document.addEventListener('keydown', e => { if (e.key === 'Escape') closeAdminNav(); });
</script>
