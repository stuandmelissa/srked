<%- include('partials/header', { title, page, navPages, socialLinks }) %>

<div class="page-banner">
  <div class="container">
    <h1><%= content.page_title %></h1>
    <% if (content.intro_text) { %><p><%= content.intro_text %></p><% } %>
  </div>
</div>

<section class="section">
  <div class="container">
    <% if (items.length === 0) { %>
      <p style="text-align:center;color:#888;">Check back soon for testimonials!</p>
    <% } else { %>
      <div class="testimonials-grid">
        <% items.forEach(t => { %>
          <div class="testimonial-card">
            <p class="testimonial-quote">"<%= t.quote %>"</p>
            <p class="testimonial-name">— <%= t.client_name %><% if (t.role) { %>, <em><%= t.role %></em><% } %></p>
          </div>
        <% }) %>
      </div>
    <% } %>
  </div>
</section>

<section class="cta-banner">
  <div class="container">
    <h2>Ready to Write Your Own Story?</h2>
    <p>Reach out and let's start your student's journey together.</p>
    <a href="/contact" class="btn btn-outline">Get in Touch</a>
  </div>
</section>

<%- include('partials/footer') %>
