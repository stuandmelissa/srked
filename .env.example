# Server
PORT=3000
NODE_ENV=development

# Database (GoDaddy provides these)
DB_HOST=localhost
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=srk_consulting

# Session (change this to a long random string in production)
SESSION_SECRET=change-me-to-something-random-and-long

# Email (for contact form notifications)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=info@srked.com
EMAIL_PASS=your_email_app_password
EMAIL_TO=info@srked.com
